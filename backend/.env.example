# EcoAI Guardian - Backend Configuration

# FastAPI Settings
PORT=8000
HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# 1. Google Gemini API Key
# Get a key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. Google Maps Platform API Key
# Ensure Directions API, Places API, and Maps Javascript API are enabled
# Get a key from: https://console.cloud.google.com/google/maps-apis/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# 3. Firebase Service Account Credentials
# Generate a service account key JSON from Firebase Console Settings -> Service Accounts
# Option A: Path to the service account credentials JSON file (absolute path recommended)
# FIREBASE_CREDENTIALS=C:/path/to/firebase-credentials.json
# Option B: Paste the raw JSON string content of the credentials file on a single line
FIREBASE_CREDENTIALS=
